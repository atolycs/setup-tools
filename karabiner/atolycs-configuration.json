{
  "title": "Atolycs configuration",
  "maintainers": [
    "atolycs"
  ],
  "rules": [
    {
      "description": "Swap caps_lock to left_control",
      "manipulators": [
        {
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_control",
              "modifiers": []
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Map ctrl + [ to escape",
      "manipulators": [
        {
          "from": {
            "key_code": "open_bracket",
            "modifiers": {
              "mandatory": [
                "control"
              ],
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "escape"
            }
          ],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Press Fn and Left Shift together to toggle Caps Lock",
      "manipulators": [
        {
          "from": {
            "key_code": "left_shift",
            "modifiers": {
              "mandatory": [
                "fn"
              ],
              "optional": [
                "caps_lock"
              ]
            }
          },
          "to": [
            {
              "hold_down_milliseconds": 200,
              "key_code": "caps_lock"
            },
            {
              "key_code": "vk_none"
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
